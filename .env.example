# Salesforce Data Cloud Ingestion API credentials
# OAuth 2.0 Connected App credentials
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret

# Your Salesforce / Data Cloud tenant URL (no trailing slash)
# e.g. https://myorg.my.salesforce.com  OR the Data Cloud tenant URL
#      https://myorg.c360a.salesforce.com
SF_TOKEN_URL=https://login.salesforce.com/services/oauth2/token

# Data Cloud Ingestion API base URL (your Data Cloud tenant URL)
# e.g. https://myorg.c360a.salesforce.com
SF_DATA_CLOUD_URL=https://your-tenant.c360a.salesforce.com

# Ingestion Source API name (the Connector you created in Data Cloud Setup)
SF_INGESTION_SOURCE=GlucoseMonitor

# Port for the web server (default 3000)
PORT=3000

# Optional: default patient ID pre-filled in the UI
DEFAULT_PATIENT_ID=PATIENT-001
